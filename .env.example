DATABASE_URL=

# Optional aliases used by some PostgreSQL hosts.
# DATABASE_URL is preferred.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

NEXT_PUBLIC_APP_URL=

AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Google OAuth callbacks:
# Staging:
# https://staging.kurioticket.com/api/auth/callback/google
#
# Production:
# https://www.kurioticket.com/api/auth/callback/google
# https://kurioticket.com/api/auth/callback/google

RESEND_API_KEY=
RESEND_FROM_EMAIL=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Travel provider mode
# Production must use TRAVEL_PROVIDER_MODE=production.
# Production must use ALLOW_SANDBOX_PROVIDERS=false.
# Production must never use sandbox/test providers.
# Fake fallback data is local-development only and additionally requires
# NODE_ENV=development with ENABLE_DEVELOPMENT_FALLBACKS=true.
TRAVEL_PROVIDER_MODE=local
ALLOW_SANDBOX_PROVIDERS=false
ENABLE_DEVELOPMENT_FALLBACKS=false

# Flight provider
# Production flight search must use Duffel live.
FLIGHT_PROVIDER_PRIMARY=duffel
DUFFEL_API_MODE=live
DUFFEL_API_KEY=

AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
KIWI_API_KEY=

# Hotel provider
# Production should keep HOTEL_PROVIDER_PRIMARY=none until a live hotel provider is approved.
HOTEL_PROVIDER_PRIMARY=none

# Staging-only KAYAK sandbox
# KAYAK sandbox requires future provider implementation before returning results.
KAYAK_API_MODE=sandbox
KAYAK_API_KEY=
KAYAK_BASE_URL=

# Hotelbeds
# HOTELBEDS_API_MODE=test and the test base URL are sandbox/test only; never use them in production.
HOTELBEDS_API_MODE=test
HOTELBEDS_API_KEY=
HOTELBEDS_SECRET=
HOTELBEDS_BASE_URL=https://api.test.hotelbeds.com

TRAVELPAYOUTS_API_KEY=
TRAVELPAYOUTS_MARKER=
HOTEL_API_KEY=

# Notes:
# - Duffel hotel/stays search is not active in this repository without a dedicated
#   Duffel Stays integration.
# - AMADEUS_CLIENT_ID / AMADEUS_CLIENT_SECRET are optional and only used when
#   HOTEL_PROVIDER_PRIMARY=amadeus_hotels in sandbox-enabled local/staging.
# - HOTEL_API_KEY / TRAVELPAYOUTS_API_KEY are optional and only used when
#   HOTEL_PROVIDER_PRIMARY=generic_partner.

ADMIN_EMAILS=admin@zentricresearch.com

# Temporary staging diagnostic toggle for /api/debug/request-location
ENABLE_REQUEST_LOCATION_DEBUG=false
REQUEST_LOCATION_DEBUG_TOKEN=

IPINFO_TOKEN=

# Server-side FX rate provider. API secrets must stay server-side; the browser only
# calls Kurioticket's /api/currency/rates endpoint.
# Production/staging XE Currency Data API setup; configure these in Render env vars.
# FX_PROVIDER_ACCOUNT_ID is the XE Account API ID (Basic Auth username).
# FX_PROVIDER_API_KEY is the XE Account API Key (Basic Auth password).
# Generic providers may still use {base}, {symbols}, and {apiKey} placeholders.
FX_PROVIDER_NAME=XE
FX_PROVIDER_URL=https://xecdapi.xe.com/v1/convert_from/?from={base}&to={symbols}&amount=1
FX_PROVIDER_ACCOUNT_ID=
FX_PROVIDER_API_KEY=
FX_RATE_CACHE_TTL_SECONDS=43200
