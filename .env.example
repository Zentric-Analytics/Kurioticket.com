DATABASE_URL=

# Optional aliases used by some PostgreSQL hosts.
# DATABASE_URL is preferred.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

NEXT_PUBLIC_APP_URL=

AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Google OAuth callbacks:
# Staging:
# https://staging.curioticket.com/api/auth/callback/google
#
# Production:
# https://www.curioticket.com/api/auth/callback/google

RESEND_API_KEY=
RESEND_FROM_EMAIL=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Powers live flight search in this repository.
DUFFEL_API_KEY=

KIWI_API_KEY=
TRAVELPAYOUTS_API_KEY=
TRAVELPAYOUTS_MARKER=

HOTEL_API_KEY=

# Hotelbeds credentials are server-side only.
HOTELBEDS_API_KEY=
HOTELBEDS_SECRET=
# Hotelbeds test API is used when this points to the test host below.
HOTELBEDS_BASE_URL=https://api.test.hotelbeds.com

# Notes:
# - Duffel hotel/stays search is not active in this repository without a dedicated
#   Duffel Stays integration.
# - AMADEUS_CLIENT_ID / AMADEUS_CLIENT_SECRET are optional and only used if configured.
# - HOTEL_API_KEY / TRAVELPAYOUTS_API_KEY are optional and only used if configured.

ADMIN_EMAILS=admin@zentricresearch.com

# Optional local-only fallback data.
# Keep disabled for production and staging.
# Fallback data is strictly local-development only and requires:
# NODE_ENV=development and ENABLE_DEVELOPMENT_FALLBACKS=true.
# Keep this false in staging/production.
ENABLE_DEVELOPMENT_FALLBACKS=false
# Temporary staging diagnostic toggle for /api/debug/request-location
ENABLE_REQUEST_LOCATION_DEBUG=false
REQUEST_LOCATION_DEBUG_TOKEN=

IPINFO_ENABLED=false
IPINFO_TOKEN=
IPINFO_BASE_URL=https://api.ipinfo.io/lite
