DATABASE_URL=

# Optional aliases used by some PostgreSQL hosts.
# DATABASE_URL is preferred.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

NEXT_PUBLIC_APP_URL=

AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Google OAuth callbacks:
# Staging:
# https://staging.kurioticket.com/api/auth/callback/google
#
# Production:
# https://www.kurioticket.com/api/auth/callback/google
# https://kurioticket.com/api/auth/callback/google

RESEND_API_KEY=
RESEND_FROM_EMAIL=
NEWSLETTER_FROM_EMAIL=
NEWSLETTER_REPLY_TO=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Travel provider mode
# Production must use TRAVEL_PROVIDER_MODE=production.
# Production must use ALLOW_SANDBOX_PROVIDERS=false.
# Production must never use sandbox/test providers.
# Fake fallback data is local-development only and additionally requires
# NODE_ENV=development with ENABLE_DEVELOPMENT_FALLBACKS=true.
TRAVEL_PROVIDER_MODE=local
ALLOW_SANDBOX_PROVIDERS=false
ENABLE_DEVELOPMENT_FALLBACKS=false

# Flight provider
# Duffel is the only active working flight provider path for the current launch.
# Production flight search must use Duffel live.
FLIGHT_PROVIDER_PRIMARY=duffel
DUFFEL_API_MODE=live
DUFFEL_API_KEY=

# Optional/future provider variables. These are not required for current launch
# unless their corresponding approved hotel or car provider is intentionally enabled.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
KIWI_API_KEY=

# Hotel provider
# Hotels remain provider-ready. Keep HOTEL_PROVIDER_PRIMARY=none until an
# approved/configured hotel provider is active for the target environment.
HOTEL_PROVIDER_PRIMARY=none

# Optional/future hotel provider mode variables. Do not treat these as current
# launch requirements unless that approved provider is intentionally enabled.
KAYAK_API_MODE=sandbox
KAYAK_API_KEY=
KAYAK_BASE_URL=

# Hotelbeds
# HOTELBEDS_API_MODE=test and the test base URL are sandbox/test only; never use them in production.
HOTELBEDS_API_MODE=test
HOTELBEDS_API_KEY=
HOTELBEDS_SECRET=
HOTELBEDS_BASE_URL=https://api.test.hotelbeds.com

TRAVELPAYOUTS_API_KEY=
TRAVELPAYOUTS_MARKER=
HOTEL_API_KEY=

# Notes:
# - Duffel hotel/stays search is not active in this repository without a dedicated
#   Duffel Stays integration.
# - Hotel and car pages should show live inventory/prices only after an approved
#   provider is active and configured for the target environment.
# - Optional/future provider variables must not be presented as active/live/working
#   provider commitments for the current launch.

ADMIN_EMAILS=admin@zentricresearch.com

# Temporary staging diagnostic toggle for /api/debug/request-location
ENABLE_REQUEST_LOCATION_DEBUG=false
REQUEST_LOCATION_DEBUG_TOKEN=

IPINFO_TOKEN=

# Server-side CurrencyFreaks FX rate provider. API secrets must stay server-side;
# the browser only calls Kurioticket's /api/currency/rates endpoint.
# FX_PROVIDER_API_KEY is server-side only. Do not prefix it with NEXT_PUBLIC_.
# FX_RATES_CRON_SECRET protects the scheduled sync endpoint. Configure Render Cron
# to call /api/internal/cron/currency-rates every 12 hours with this secret.
FX_PROVIDER_NAME=CurrencyFreaks
FX_PROVIDER_URL=https://api.currencyfreaks.com/v2.0/rates/latest?apikey={apiKey}&base={base}
FX_PROVIDER_API_KEY=
FX_RATE_CACHE_TTL_SECONDS=43200
FX_RATES_CRON_SECRET=
