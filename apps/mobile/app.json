{
  "expo": {
    "name": "Kurioticket",
    "slug": "kurioticket-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "kurioticket",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kurioticket.mobile"
    },
    "android": {
      "package": "com.kurioticket.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/kurioticket-icon-blue.png",
        "backgroundColor": "#F2F6FA"
      }
    },
    "plugins": [
      "expo-router"
    ],
    "icon": "./assets/kurioticket-icon-blue.png",
    "splash": {
      "image": "./assets/kurioticket-logo-primary-light-bg.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2F6FA"
    }
  }
}
